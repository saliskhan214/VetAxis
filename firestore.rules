rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────────────────────────
    // GLOBAL SAFETY NET
    // ─────────────────────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────────────────────────
    // SECURE REUSABLE HELPER PRIMITIVES
    // ─────────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ─────────────────────────────────────────────────────────────────
    // USERS COLLECTION Rules
    // ─────────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow get: if isSignedIn() && (
        isOwner(userId) ||
        resource.data.role != 'user'
      );
      
      allow list: if isSignedIn() && (
        resource.data.role != 'user'
      );

      allow create: if isSignedIn() && isOwner(userId) && (
        incoming().keys().hasAll(['name', 'email', 'role', 'createdAt']) &&
        incoming().createdAt is number && incoming().createdAt <= request.time.toMillis() + 60000 &&
        incoming().role in ['doctor', 'clinic', 'assistant', 'user'] &&
        incoming().name is string && incoming().name.size() <= 80 &&
        incoming().email is string && incoming().email.size() <= 128 &&
        (!('phone' in incoming()) || (incoming().phone is string && incoming().phone.size() <= 20)) &&
        (!('expertise' in incoming()) || (incoming().expertise is string && incoming().expertise.size() <= 200)) &&
        (!('facilities' in incoming()) || (incoming().facilities is string && incoming().facilities.size() <= 200)) &&
        (!('address' in incoming()) || (incoming().address is string && incoming().address.size() <= 200)) &&
        (!('profilePic' in incoming()) || (incoming().profilePic is string && incoming().profilePic.size() <= 2 * 1024 * 1024)) &&
        (!('isVerified' in incoming()) || incoming().isVerified == false) && // Block self-verification during registration
        (!('subscriptionTier' in incoming()) || incoming().subscriptionTier in ['Silver', 'Gold', 'Platinum']) &&
        (!('subscriptionExpiresAt' in incoming()) || incoming().subscriptionExpiresAt is number) &&
        (!('emailVerified' in incoming()) || incoming().emailVerified is bool)
      );

      // Protect against privilege escalation and role-switching attacks
      allow update: if isSignedIn() && isOwner(userId) && (
        incoming().role == existing().role &&
        incoming().email == existing().email &&
        incoming().createdAt == existing().createdAt &&
        (!('isVerified' in incoming()) || incoming().isVerified == existing().isVerified) && // Guard: cannot self-verify
        (!('subscriptionTier' in incoming()) || incoming().subscriptionTier in ['Silver', 'Gold', 'Platinum']) &&
        (!('subscriptionExpiresAt' in incoming()) || incoming().subscriptionExpiresAt is number) &&
        (!('emailVerified' in incoming()) || (incoming().emailVerified is bool && (incoming().emailVerified == existing().emailVerified || incoming().emailVerified == request.auth.token.email_verified))) &&
        incoming().name is string && incoming().name.size() <= 80 &&
        (!('phone' in incoming()) || (incoming().phone is string && incoming().phone.size() <= 20)) &&
        (!('expertise' in incoming()) || (incoming().expertise is string && incoming().expertise.size() <= 200)) &&
        (!('facilities' in incoming()) || (incoming().facilities is string && incoming().facilities.size() <= 200)) &&
        (!('address' in incoming()) || (incoming().address is string && incoming().address.size() <= 200)) &&
        (!('profilePic' in incoming()) || (incoming().profilePic is string && incoming().profilePic.size() <= 2 * 1024 * 1024))
      );
      
      allow delete: if isOwner(userId);

      // ───────────────────────────────────────────────────────────────
      // REVIEWS SUBCOLLECTION (users/{userId}/reviews/{reviewId})
      // ───────────────────────────────────────────────────────────────
      match /reviews/{reviewId} {
        // Any signed-in user can view clinican reviews
        allow read: if isSignedIn();

        allow create: if isSignedIn() && (
          // Reviewer can write review of someone else
          userId != request.auth.uid &&
          incoming().reviewerEmail == request.auth.token.email &&
          incoming().reviewerName is string &&
          incoming().reviewerRole in ['doctor', 'clinic', 'assistant', 'user'] &&
          incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5 &&
          (!('comment' in incoming()) || (incoming().comment is string && incoming().comment.size() <= 1000)) &&
          incoming().date is number && incoming().date <= request.time.toMillis() + 60000 &&
          // Verify that the person being rated is actually a clinician (not a plain user)
          get(/databases/$(database)/documents/users/$(userId)).data.role != 'user'
        );

        allow update: if isSignedIn() && (
          // Reviewer update
          existing().reviewerEmail == request.auth.token.email &&
          incoming().reviewerEmail == existing().reviewerEmail &&
          incoming().rating is number && incoming().rating >= 1 && incoming().rating <= 5 &&
          (!('comment' in incoming()) || (incoming().comment is string && incoming().comment.size() <= 1000)) &&
          incoming().date == existing().date
        );

        allow delete: if isSignedIn() && (
          existing().reviewerEmail == request.auth.token.email
        );
      }
    }

    // ─────────────────────────────────────────────────────────────────
    // PET ADS RULES (Classifieds)
    // ─────────────────────────────────────────────────────────────────
    match /pet_ads/{adId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && (
        incoming().ownerEmail == request.auth.token.email &&
        incoming().ownerRole in ['doctor', 'clinic', 'assistant', 'user'] &&
        incoming().adType in ['sale', 'adoption'] &&
        incoming().petType is string && incoming().petType.size() <= 50 &&
        incoming().description is string && incoming().description.size() <= 1500 &&
        incoming().location is string && incoming().location.size() <= 100 &&
        incoming().whatsapp is string && incoming().whatsapp.size() <= 24 &&
        incoming().createdAt is number && incoming().createdAt <= request.time.toMillis() + 60000 &&
        (!('price' in incoming()) || (incoming().price is number && incoming().price >= 0)) &&
        (!('image' in incoming()) || (incoming().image is string && incoming().image.size() <= 2 * 1024 * 1024))
      );

      allow update: if isSignedIn() && (
        existing().ownerEmail == request.auth.token.email &&
        incoming().ownerEmail == existing().ownerEmail &&
        incoming().ownerRole == existing().ownerRole &&
        incoming().createdAt == existing().createdAt &&
        incoming().adType == existing().adType &&
        incoming().petType is string && incoming().petType.size() <= 50 &&
        incoming().description is string && incoming().description.size() <= 1500 &&
        incoming().location is string && incoming().location.size() <= 100 &&
        incoming().whatsapp is string && incoming().whatsapp.size() <= 24 &&
        (!('price' in incoming()) || (incoming().price is number && incoming().price >= 0)) &&
        (!('image' in incoming()) || (incoming().image is string && incoming().image.size() <= 2 * 1024 * 1024))
      );

      allow delete: if isSignedIn() && (
        existing().ownerEmail == request.auth.token.email
      );
    }

    // ─────────────────────────────────────────────────────────────────
    // MARKETPLACE PRODUCTS RULES
    // ─────────────────────────────────────────────────────────────────
    match /marketplace_products/{productId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && (
        // Authority check: Only Clinicians (Doctors or Clinics) can post marketplace items
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['doctor', 'clinic'] &&
        incoming().ownerEmail == request.auth.token.email &&
        incoming().ownerRole in ['doctor', 'clinic'] &&
        incoming().name is string && incoming().name.size() <= 100 &&
        incoming().price is number && incoming().price >= 0 &&
        incoming().quantity is number && incoming().quantity >= 1 &&
        incoming().description is string && incoming().description.size() <= 1500 &&
        incoming().whatsapp is string && incoming().whatsapp.size() <= 24 &&
        incoming().createdAt is number && incoming().createdAt <= request.time.toMillis() + 60000 &&
        (!('image' in incoming()) || (incoming().image is string && incoming().image.size() <= 2 * 1024 * 1024))
      );

      allow update: if isSignedIn() && (
        existing().ownerEmail == request.auth.token.email &&
        incoming().ownerEmail == existing().ownerEmail &&
        incoming().ownerRole == existing().ownerRole &&
        incoming().createdAt == existing().createdAt &&
        incoming().name is string && incoming().name.size() <= 100 &&
        incoming().price is number && incoming().price >= 0 &&
        incoming().quantity is number && incoming().quantity >= 0 &&
        incoming().description is string && incoming().description.size() <= 1500 &&
        incoming().whatsapp is string && incoming().whatsapp.size() <= 24 &&
        (!('image' in incoming()) || (incoming().image is string && incoming().image.size() <= 2 * 1024 * 1024))
      );

      allow delete: if isSignedIn() && (
        existing().ownerEmail == request.auth.token.email
      );
    }

    // ─────────────────────────────────────────────────────────────────
    // COMMUNITY POSTS RULES
    // ─────────────────────────────────────────────────────────────────
    match /community_posts/{postId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && (
        (incoming().authorEmail == request.auth.token.email || ('authorUid' in incoming() && incoming().authorUid == request.auth.uid)) &&
        incoming().text is string && incoming().text.size() <= 1500 &&
        incoming().category in ['lost', 'adoption', 'help', 'general'] &&
        incoming().ts is number && incoming().ts <= request.time.toMillis() + 60000 &&
        (!('title' in incoming()) || (incoming().title is string && incoming().title.size() <= 200)) &&
        (!('imageUrl' in incoming()) || (incoming().imageUrl is string && incoming().imageUrl.size() <= 2000)) &&
        (!('images' in incoming()) || (incoming().images is list)) &&
        (!('authorUid' in incoming()) || (incoming().authorUid is string && incoming().authorUid == request.auth.uid)) &&
        (!('isBoosted' in incoming()) || (incoming().isBoosted is bool)) &&
        (!('boostDetails' in incoming()) || (incoming().boostDetails is map)) &&
         // Strict empty reactions check on create to prevent validation forgery
        incoming().reactions is map &&
        incoming().reactions['❤️'] is list && incoming().reactions['❤️'].size() == 0 &&
        incoming().reactions['👍'] is list && incoming().reactions['👍'].size() == 0 &&
        incoming().reactions['❗'] is list && incoming().reactions['❗'].size() == 0
      );

      // Update allows toggling of reactions, post editing, or emergency radar boosting
      allow update: if isSignedIn() && (
        // Option A: Owner edits post
        (
          (existing().authorEmail == request.auth.token.email || ('authorUid' in existing() && existing().authorUid == request.auth.uid)) &&
          incoming().authorEmail == existing().authorEmail &&
          incoming().ts == existing().ts &&
          incoming().text is string && incoming().text.size() <= 1500 &&
          incoming().category in ['lost', 'adoption', 'help', 'general'] &&
          (!('title' in incoming()) || (incoming().title is string && incoming().title.size() <= 200)) &&
          (!('imageUrl' in incoming()) || (incoming().imageUrl is string && incoming().imageUrl.size() <= 2000)) &&
          (!('images' in incoming()) || (incoming().images is list))
        ) ||
        // Option B: Someone else reacts to the post. Diff must contain ONLY changed reactions list
        (
          incoming().authorEmail == existing().authorEmail &&
          incoming().ts == existing().ts &&
          incoming().text == existing().text &&
          incoming().category == existing().category &&
          incoming().reactions is map
        ) ||
        // Option C: Owner triggers Priority Boost transaction state
        (
          (existing().authorEmail == request.auth.token.email || ('authorUid' in existing() && existing().authorUid == request.auth.uid)) &&
          incoming().authorEmail == existing().authorEmail &&
          incoming().ts == existing().ts &&
          incoming().text == existing().text &&
          incoming().category == existing().category &&
          incoming().isBoosted == true &&
          incoming().boostDetails is map &&
          incoming().boostDetails.amountPaid is number &&
          incoming().boostDetails.radiusKm is number &&
          incoming().boostDetails.lastSeenLoc is map
        )
      );

      allow delete: if isSignedIn() && (
        existing().get('authorEmail', '') == request.auth.token.email ||
        existing().get('authorUid', '') == request.auth.uid
      );
    }

    // ─────────────────────────────────────────────────────────────────
    // JOB POSTS COLLECTION Rules
    // ─────────────────────────────────────────────────────────────────
    match /job_posts/{jobId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'clinic' &&
        incoming().get('clinicId', '') == request.auth.uid &&
        incoming().get('clinicEmail', '') == request.auth.token.email &&
        incoming().title is string && incoming().title.size() <= 150 &&
        incoming().jobType in ['Full-time', 'Part-time', 'Freelance', 'Internship'] &&
        incoming().location is string && incoming().location.size() <= 150 &&
        incoming().salaryMin is number && incoming().salaryMin >= 0 &&
        incoming().salaryMax is number && incoming().salaryMax >= incoming().salaryMin &&
        incoming().experience is string && incoming().experience.size() <= 1000 &&
        incoming().workingHours is string && incoming().workingHours.size() <= 1000 &&
        incoming().genderPreference in ['No Preference', 'Male', 'Female'] &&
        incoming().deadline is string && incoming().deadline.size() <= 50 &&
        incoming().positions is number && incoming().positions >= 1 &&
        incoming().status == 'open' &&
        incoming().screeningQuestions is list &&
        incoming().requiredDocuments is list &&
        incoming().minQualificationGate in ['none', 'assistant', 'doctor'] &&
        incoming().createdAt is number && incoming().createdAt <= request.time.toMillis() + 60000 &&
        incoming().get('clinicAddress', '') is string && incoming().get('clinicAddress', '').size() <= 400 &&
        incoming().get('clinicWebsite', '') is string && incoming().get('clinicWebsite', '').size() <= 200 &&
        incoming().get('clinicContactPhone', '') is string && incoming().get('clinicContactPhone', '').size() <= 50 &&
        incoming().get('clinicFacilities', '') is string && incoming().get('clinicFacilities', '').size() <= 400
      );

      allow update: if isSignedIn() && (
        (existing().get('clinicId', '') == request.auth.uid || existing().get('clinicEmail', '') == request.auth.token.email) &&
        incoming().get('clinicId', '') == existing().get('clinicId', '') &&
        incoming().get('createdAt', 0) == existing().get('createdAt', 0) &&
        incoming().title is string && incoming().title.size() <= 150 &&
        incoming().jobType in ['Full-time', 'Part-time', 'Freelance', 'Internship'] &&
        incoming().location is string && incoming().location.size() <= 150 &&
        incoming().salaryMin is number && incoming().salaryMin >= 0 &&
        incoming().salaryMax is number && incoming().salaryMax >= incoming().salaryMin &&
        incoming().experience is string && incoming().experience.size() <= 1000 &&
        incoming().workingHours is string && incoming().workingHours.size() <= 1000 &&
        incoming().genderPreference in ['No Preference', 'Male', 'Female'] &&
        incoming().deadline is string && incoming().deadline.size() <= 50 &&
        incoming().positions is number && incoming().positions >= 1 &&
        incoming().status in ['open', 'closed'] &&
        incoming().screeningQuestions is list &&
        incoming().requiredDocuments is list &&
        incoming().minQualificationGate in ['none', 'assistant', 'doctor'] &&
        incoming().get('clinicAddress', '') is string && incoming().get('clinicAddress', '').size() <= 400 &&
        incoming().get('clinicWebsite', '') is string && incoming().get('clinicWebsite', '').size() <= 200 &&
        incoming().get('clinicContactPhone', '') is string && incoming().get('clinicContactPhone', '').size() <= 50 &&
        incoming().get('clinicFacilities', '') is string && incoming().get('clinicFacilities', '').size() <= 400
      );

      allow delete: if isSignedIn() && (
        existing().get('clinicId', '') == request.auth.uid ||
        existing().get('clinicEmail', '') == request.auth.token.email
      );
    }

    // ─────────────────────────────────────────────────────────────────
    // JOB APPLICATIONS COLLECTION Rules
    // ─────────────────────────────────────────────────────────────────
    match /job_applications/{applicationId} {
      allow read: if isSignedIn() && (
        resource.data.get('applicantId', '') == request.auth.uid ||
        resource.data.get('clinicId', '') == request.auth.uid ||
        resource.data.get('clinicEmail', '') == request.auth.token.email
      );

      allow create: if isSignedIn() && (
        incoming().get('applicantId', '') == request.auth.uid &&
        incoming().get('applicantEmail', '') == request.auth.token.email &&
        incoming().applicantName is string && incoming().applicantName.size() <= 150 &&
        incoming().applicantPhone is string && incoming().applicantPhone.size() <= 24 &&
        incoming().status == 'Pending' &&
        incoming().createdAt is number && incoming().createdAt <= request.time.toMillis() + 60000
      );

      allow update: if isSignedIn() && (
        // Only the clinic owning the job post can update the application status
        (existing().get('clinicId', '') == request.auth.uid || existing().get('clinicEmail', '') == request.auth.token.email) &&
        incoming().get('clinicId', '') == existing().get('clinicId', '') &&
        incoming().get('jobId', '') == existing().get('jobId', '') &&
        incoming().get('applicantId', '') == existing().get('applicantId', '') &&
        incoming().get('applicantEmail', '') == existing().get('applicantEmail', '') &&
        incoming().get('applicantName', '') == existing().get('applicantName', '') &&
        incoming().get('applicantPhone', '') == existing().get('applicantPhone', '') &&
        incoming().answers == existing().answers &&
        incoming().submittedDocs == existing().submittedDocs &&
        incoming().get('createdAt', 0) == existing().get('createdAt', 0) &&
        incoming().status in ['Pending', 'Reviewed', 'Shortlisted', 'Rejected', 'Hired']
      );

      allow delete: if isSignedIn() && (
        existing().get('applicantId', '') == request.auth.uid ||
        existing().get('clinicId', '') == request.auth.uid ||
        existing().get('clinicEmail', '') == request.auth.token.email
      );
    }

    // ─────────────────────────────────────────────────────────────────
    // NOTIFICATIONS COLLECTION Rules
    // ─────────────────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read, delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      
      allow update: if isSignedIn() && (
        existing().userId == request.auth.uid &&
        incoming().userId == existing().userId &&
        incoming().senderId == existing().senderId &&
        incoming().message == existing().message
      );
    }

    // ─────────────────────────────────────────────────────────────────
    // LIVESTOCK FARMS RULES
    // ─────────────────────────────────────────────────────────────────
    match /livestock_farms/{farmId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && (
        incoming().ownerUid == request.auth.uid &&
        incoming().name is string && incoming().name.size() <= 150 &&
        incoming().location is string && incoming().location.size() <= 200 &&
        incoming().farmType in ['Poultry Farm', 'Dairy Farm', 'Buffalo Farm', 'Goat Farm', 'Sheep Farm', 'Mixed Farm']
      );

      allow update: if isSignedIn() && (
        // Farm Owner can edit farm details
        existing().ownerUid == request.auth.uid ||
        // Or assigned vet can update status or notes
        existing().managerUid == request.auth.uid ||
        // Allow vet to link / decline when requested
        (existing().get('managerStatus', '') == 'pending' && incoming().managerUid == request.auth.uid) ||
        // Allow updating teams or records
        (incoming().ownerUid == existing().ownerUid)
      );

      allow delete: if isSignedIn() && (
        existing().ownerUid == request.auth.uid
      );
    }

    // ─────────────────────────────────────────────────────────────────
    // LIVESTOCK ANIMALS RULES
    // ─────────────────────────────────────────────────────────────────
    match /livestock_animals/{animalId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ─────────────────────────────────────────────────────────────────
    // LIVESTOCK BATCHES RULES
    // ─────────────────────────────────────────────────────────────────
    match /livestock_batches/{batchId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }

    // ─────────────────────────────────────────────────────────────────
    // LIVESTOCK TASKS RULES
    // ─────────────────────────────────────────────────────────────────
    match /livestock_tasks/{taskId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn();
    }
  }
}
